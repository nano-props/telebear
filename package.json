{
  "name": "telebear",
  "version": "0.1.0",
  "description": "Temporary SSH server with FRP tunnel - TUI",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun src/main.ts",
    "build": "bun build src/main.ts --compile --outfile dist/telebear",
    "clean": "rm -rf dist .*.bun-build"
  },
  "dependencies": {
    "ink": "7.0.0",
    "ink-spinner": "5.0.0",
    "react": "19.2.5",
    "smol-toml": "1.6.1",
    "ssh2": "1.17.0",
    "zod": "4.3.6",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/ssh2": "1.15.5",
    "tsx": "4.21.0",
    "typescript": "6.0.2"
  }
}
